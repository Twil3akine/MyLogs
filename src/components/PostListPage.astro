---
import DateText from "@/components/DateText.astro";
import Tag from "@/components/Tag.astro";
import TagSelect from "@/components/TagSelect.astro";
import type { PostListItem } from "@/lib/content";

interface Props {
  title: string;
  description: string;
  posts: PostListItem[];
  locale?: "ja" | "en";
}

const { title, description, posts, locale = "ja" } = Astro.props;
const allTags = Array.from(new Set(posts.flatMap((post) => post.tags))).sort((a, b) =>
  a.localeCompare(b),
);
const tagCounts = new Map(
  allTags.map((tag) => [tag, posts.filter((post) => post.tags.includes(tag)).length]),
);
const tagOptions = allTags.map((tag) => ({
  value: tag,
  count: tagCounts.get(tag) ?? 0,
}));
---

<section class="post-list-page" data-post-list-page>
  <header>
    <h1>{title}</h1>
    <p>{description}</p>
  </header>

  {
    allTags.length > 0 && (
      <div class="filter-panel">
        <TagSelect options={tagOptions} totalCount={posts.length} locale={locale} />
      </div>
    )
  }

  <div class="post-list">
    {
      posts.map((post) => (
        <article class="post-card" data-tags={post.tags.join("|")}>
          <div class="post-meta">
            <DateText date={post.date} size="large" />
          </div>
          <h2>
            <a class="post-title-link" href={post.href}>{post.title}</a>
          </h2>
          <p>{post.description}</p>
          <ul>
            {post.tags.map((tag) => (
              <li>
                <Tag as="button" type="button" data-filter-tag={tag}>{tag}</Tag>
              </li>
            ))}
          </ul>
        </article>
      ))
    }
  </div>
</section>

<script>
  const initPostFilters = () => {
    document.querySelectorAll<HTMLElement>("[data-post-list-page]").forEach((page) => {
      const cards = Array.from(page.querySelectorAll<HTMLElement>("[data-tags]"));
      const buttons = Array.from(page.querySelectorAll<HTMLButtonElement>("[data-filter-tag]"));
      const availableTags = new Set(cards.flatMap((card) => (card.dataset.tags || "").split("|").filter(Boolean)));

      const applyFilter = (tag: string | null, updateURL = false) => {
        const selectedTag = tag && availableTags.has(tag) ? tag : null;
        cards.forEach((card) => {
          const tags = (card.dataset.tags || "").split("|");
          card.hidden = selectedTag !== null && !tags.includes(selectedTag);
        });

        buttons.forEach((button) => {
          button.setAttribute(
            "aria-pressed",
            String((button.dataset.filterTag || null) === selectedTag),
          );
        });

        page.dataset.activeTag = selectedTag || "";

        if (updateURL) {
          const url = new URL(window.location.href);
          if (selectedTag) {
            url.searchParams.set("tag", selectedTag);
          } else {
            url.searchParams.delete("tag");
          }
          window.history.pushState({}, "", url);
        }
      };

      if (page.dataset.filterInitialized !== "true") {
        page.dataset.filterInitialized = "true";
        buttons.forEach((button) => {
          button.onclick = () => {
            const tag = button.dataset.filterTag || null;
            const nextTag = tag && page.dataset.activeTag === tag ? null : tag;
            applyFilter(nextTag, true);
          };
        });
      }

      applyFilter(new URL(window.location.href).searchParams.get("tag"));
    });
  };

  initPostFilters();
  document.addEventListener("astro:page-load", initPostFilters);
  window.addEventListener("popstate", initPostFilters);
</script>

<style>
  .post-list-page {
    width: 100%;
    margin: 0 auto;
    padding: clamp(2.5rem, 7vw, 5rem) 0;
  }

  .post-list-page header {
    margin-bottom: 2.25rem;
  }

  .post-list-page h1 {
    margin: 0;
    font-size: var(--font-size-page-title);
    line-height: 1.05;
  }

  .post-list-page header p {
    margin: 1.2rem 0 0;
    color: color-mix(in srgb, var(--theme-text), transparent 22%);
    font-size: var(--font-size-body-large);
    line-height: 1.9;
  }

  .filter-panel {
    margin: -0.65rem 0 0;
    padding: 1rem 0;
    border-top: 1px solid var(--theme-border);
  }

  .post-list {
    display: grid;
    border-top: 1px solid var(--theme-border);
  }

  .post-card {
    display: grid;
    gap: 0.5rem;
    padding: 1.45rem 0 1.55rem;
    border-bottom: 1px solid var(--theme-border);
    color: var(--theme-text);
  }

  .post-card[hidden] {
    display: none;
  }

  .post-meta {
    margin: 0;
  }

  .post-card h2 {
    margin: 0;
    font-size: var(--font-size-card-title);
    line-height: 1.35;
    transition: color 0.2s ease;
  }

  .post-title-link {
    color: inherit;
    text-decoration: none;
  }

  .post-title-link:hover {
    color: var(--theme-accent);
  }

  .post-card p {
    max-width: 42rem;
    margin: 0;
    color: color-mix(in srgb, var(--theme-text), transparent 24%);
    line-height: 1.75;
  }

  .post-card ul {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin: 0.2rem 0 0;
    padding: 0;
    list-style: none;
  }

  @media (max-width: 640px) {
    .post-list-page {
      padding: 2rem 0 3rem;
    }

    .post-card {
      gap: 0.55rem;
    }

  }
</style>
