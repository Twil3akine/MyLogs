---
import { profileLanding } from "@/data/profileLanding";
import type { Locale } from "@/data/locales";

interface Props {
  locale?: Locale;
}

const { locale = "ja" } = Astro.props;
const profile = profileLanding[locale];
---

<section class="landing">
  <aside class="profile-card" aria-label={profile.ariaLabel}>
    <img
      class="profile-avatar"
      src="/avatar.png"
      alt={profile.avatarAlt}
      width="128"
      height="128"
    />

    <div class="profile-heading">
      <h1>Twil3akine</h1>
    </div>

    <p class="profile-bio">{profile.bio}</p>

    <dl class="profile-meta">
      <div>
        <dt>
          <svg aria-hidden="true" viewBox="0 0 24 24">
            <path d="M20 10c0 5-8 12-8 12S4 15 4 10a8 8 0 1 1 16 0Z"></path>
            <circle cx="12" cy="10" r="3"></circle>
          </svg>
          {profile.locationLabel}
        </dt>
        <dd>{profile.location}</dd>
      </div>
      <div>
        <dt>
          <svg aria-hidden="true" viewBox="0 0 24 24">
            <path d="M3 21h18"></path>
            <path d="M5 21V7l8-4v18"></path>
            <path d="M19 21V11l-6-4"></path>
          </svg>
          {profile.affiliationLabel}
        </dt>
        <dd>{profile.affiliation}</dd>
      </div>
      <div>
        <dt>
          <svg aria-hidden="true" viewBox="0 0 24 24">
            <path d="M4 19.5V5a2 2 0 0 1 2-2h12v16H6a2 2 0 0 0-2 2"></path>
            <path d="M8 7h6"></path>
            <path d="M8 11h8"></path>
          </svg>
          {profile.researchLabel}
        </dt>
        <dd>{profile.research}</dd>
      </div>
    </dl>

    <div class="social-links" aria-label="Social Links">
      <p>Social Links</p>
      <a href="https://github.com/twil3akine" target="_blank" rel="noopener noreferrer">
        <svg aria-hidden="true" viewBox="0 0 24 24">
          <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.1-1.3-.3-2.5-1-3.5.3-1.2.3-2.4 0-3.5 0 0-1 0-3 1.5-2.6-.5-5.4-.5-8 0C6 2 5 2 5 2c-.3 1.1-.3 2.3 0 3.5A5.4 5.4 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.4.5-.7 1.1-.9 1.7-.2.6-.2 1.2-.1 1.8v4"></path>
          <path d="M9 18c-4.5 2-5-2-7-2"></path>
        </svg>
        GitHub
      </a>
      <a href="https://twitter.com/twil3akine" target="_blank" rel="noopener noreferrer">
        <svg aria-hidden="true" viewBox="0 0 24 24">
          <path d="M23 4.5c-.8.4-1.7.6-2.6.7.9-.6 1.6-1.5 2-2.6-.9.5-1.8.9-2.9 1.1A4.5 4.5 0 0 0 11.8 7c0 .4 0 .7.1 1C8.2 7.8 4.8 6 2.5 3.2c-.4.7-.6 1.5-.6 2.3 0 1.6.8 3 2.1 3.8-.8 0-1.5-.2-2.1-.6v.1c0 2.2 1.6 4 3.6 4.5-.4.1-.8.2-1.2.2-.3 0-.6 0-.9-.1.6 1.8 2.2 3.1 4.2 3.1A9.1 9.1 0 0 1 2 18.4c-.4 0-.7 0-1-.1A12.9 12.9 0 0 0 8 20.5c8.4 0 13-7 13-13v-.6c.9-.6 1.6-1.4 2.2-2.3Z"></path>
        </svg>
        Twitter
      </a>
      <a href="https://atcoder.jp/users/twil3" target="_blank" rel="noopener noreferrer">
        <svg aria-hidden="true" viewBox="0 0 24 24">
          <path d="M4 19 10 5l4 9 2-5 4 10"></path>
          <path d="M8 14h7"></path>
        </svg>
        AtCoder
      </a>
      <a href="https://clist.by/coder/Twil3akine/" target="_blank" rel="noopener noreferrer">
        <svg aria-hidden="true" viewBox="0 0 24 24">
          <path d="M8 6h13"></path>
          <path d="M8 12h13"></path>
          <path d="M8 18h13"></path>
          <path d="m3 6 .7.7L5.5 5"></path>
          <path d="m3 12 .7.7 1.8-1.7"></path>
          <path d="m3 18 .7.7 1.8-1.7"></path>
        </svg>
        CLIST
      </a>
    </div>
  </aside>

  <div class="landing-side" aria-label="Content" style={`--section-count: ${profile.sections.length}`}>
    {
      profile.sections.map((section, index) => (
        <a class="content-link" href={section.href}>
          <span class="content-number">{String(index + 1).padStart(2, "0")}</span>
          <span class="content-body">
            <span class="content-label">{section.label}</span>
            <strong>{section.title}</strong>
            <small>{section.description}</small>
          </span>
          <svg aria-hidden="true" viewBox="0 0 24 24">
            <path d="M7 17 17 7"></path>
            <path d="M8 7h9v9"></path>
          </svg>
        </a>
      ))
    }
  </div>
</section>

<style>
  :global(html) {
    height: 100%;
    overflow: hidden;
  }

  :global(body) {
    height: 100svh;
    min-height: 100svh;
    overflow-x: hidden;
    overflow-y: hidden;
  }

  :global(.layout-container) {
    padding-top: 0.25rem;
    padding-bottom: 0.25rem;
    flex: 1;
    align-items: center;
  }

  :global(main.main-content) {
    max-width: none;
    width: 100%;
    padding: 0;
  }

  :global(.footer-inner) {
    padding-top: 0.5rem;
    padding-bottom: 0.5rem;
  }

  .landing {
    display: grid;
    grid-template-columns: minmax(300px, 360px) minmax(460px, 1fr);
    gap: clamp(2rem, 6vw, 4.5rem);
    align-items: stretch;
    width: 100%;
    max-height: 100%;
    padding: 0;
    transform: translateY(1rem);
  }

  .profile-card {
    width: min(100%, 360px);
    margin-block: 0;
  }

  .landing-side {
    display: grid;
    align-content: stretch;
    grid-template-rows: repeat(var(--section-count), 1fr);
    max-width: 640px;
    min-height: 100%;
    border-left: 1px solid var(--theme-border);
    padding-left: clamp(1.5rem, 4vw, 2.75rem);
  }

  .content-link {
    display: flex;
    align-items: center;
    gap: 1.1rem;
    min-height: 6.35rem;
    border-bottom: 1px solid var(--theme-border);
    color: var(--theme-text);
    text-decoration: none;
    transition:
      color 0.2s ease,
      transform 0.2s ease;
  }

  .content-link:last-child {
    border-bottom: 0;
  }

  .content-number {
    color: color-mix(in srgb, var(--theme-text), transparent 55%);
    font-family: var(--theme-font-mono);
    font-size: 0.9rem;
    font-weight: 700;
  }

  .content-body {
    display: grid;
    gap: 0.32rem;
    min-width: 0;
    flex: 1;
  }

  .content-label {
    color: var(--theme-accent);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .content-link strong {
    max-width: 32rem;
    font-size: var(--font-size-card-title);
    font-weight: 800;
    line-height: 1.25;
    text-wrap: balance;
  }

  .content-link small {
    max-width: 38rem;
    color: color-mix(in srgb, var(--theme-text), transparent 35%);
    font-size: 0.88rem;
    line-height: 1.55;
  }

  .content-link svg {
    width: 1.05rem;
    height: 1.05rem;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 2;
    flex: 0 0 auto;
    opacity: 0.55;
    transition:
      opacity 0.2s ease,
      transform 0.2s ease;
  }

  .content-link:hover {
    color: var(--theme-accent);
    transform: translateX(0.15rem);
  }

  .content-link:hover svg {
    opacity: 1;
    transform: translate(0.1rem, -0.1rem);
  }

  .profile-avatar {
    display: block;
    width: 16rem;
    aspect-ratio: 1;
    height: auto;
    margin: 0 auto;
    object-fit: cover;
    border: 1px solid var(--theme-border);
    border-radius: 50%;
    background: var(--theme-accent-bg);
  }

  .profile-heading {
    margin-top: 0.8rem;
  }

  .profile-heading h1 {
    margin: 0;
    font-size: var(--font-size-profile-name);
    line-height: 1.1;
  }

  .profile-bio {
    margin: 0.7rem 0 0.9rem;
    font-size: 0.98rem;
    line-height: 1.6;
  }

  .profile-meta {
    display: grid;
    gap: 0.48rem;
    margin: 0 0 0.9rem;
  }

  .profile-meta div {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    border-bottom: 1px solid var(--theme-border);
    padding-bottom: 0.48rem;
  }

  .profile-meta dt,
  .social-links p {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    color: color-mix(in srgb, var(--theme-text), transparent 35%);
    font-size: 0.86rem;
    font-weight: 600;
  }

  .profile-meta dd {
    margin: 0;
    text-align: right;
    font-size: 0.94rem;
    font-weight: 600;
  }

  .profile-card svg {
    width: 1rem;
    height: 1rem;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 2;
    flex: 0 0 auto;
  }

  .social-links {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.35rem;
  }

  .social-links p {
    grid-column: 1 / -1;
    margin: 0;
  }

  .social-links a {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    min-height: 2rem;
    color: var(--theme-text);
    text-decoration: none;
    border: 1px solid var(--theme-border);
    border-radius: 8px;
    padding: 0 0.75rem;
    font-size: 0.92rem;
    font-weight: 700;
    transition:
      border-color 0.2s ease,
      color 0.2s ease,
      background-color 0.2s ease;
  }

  .social-links a:hover {
    border-color: var(--theme-accent);
    color: var(--theme-accent);
    background-color: var(--theme-accent-bg);
  }

  @media (max-height: 720px) {
    .landing {
      transform: none;
    }

    :global(.layout-container) {
      padding-top: 0.1rem;
      padding-bottom: 0.1rem;
    }

    :global(.footer-inner) {
      padding-top: 0.55rem;
      padding-bottom: 0.55rem;
    }

    .profile-avatar {
      width: 12rem;
    }

    .content-link {
      min-height: 5.75rem;
    }

    .content-link strong {
      font-size: 1.05rem;
    }

    .content-link small {
      font-size: 0.76rem;
      line-height: 1.4;
    }

    .profile-heading {
      margin-top: 0.65rem;
    }

    .profile-bio {
      margin: 0.55rem 0 0.7rem;
      line-height: 1.45;
    }

    .profile-meta {
      gap: 0.36rem;
      margin-bottom: 0.7rem;
    }

    .profile-meta div {
      padding-bottom: 0.36rem;
    }

    .social-links {
      gap: 0.28rem;
    }

    .social-links a {
      min-height: 1.85rem;
    }
  }

  @media (max-width: 877px) {
    :global(html) {
      height: auto;
      overflow: auto;
    }

    :global(body) {
      height: auto;
      min-height: 100svh;
      overflow-x: hidden;
      overflow-y: auto;
    }

    :global(.layout-container) {
      padding: 0.5rem 1.25rem;
    }

    .landing {
      display: block;
      min-height: auto;
      transform: none;
    }

    .profile-card {
      width: 100%;
    }

    .profile-avatar {
      width: min(19.5rem, 100%);
    }

    .profile-heading {
      margin-top: 0.7rem;
    }

    .profile-heading h1 {
      font-size: 1.6rem;
    }

    .social-links {
      grid-template-columns: 1fr;
    }

    .landing-side {
      max-width: none;
      min-height: 0;
      grid-template-rows: none;
      border-left: 0;
      border-top: 1px solid var(--theme-border);
      margin-top: 2rem;
      padding-top: 1.5rem;
      padding-left: 0;
    }

    .content-link {
      box-sizing: border-box;
      min-height: 10rem;
      padding: 1.5rem 0;
    }
  }
</style>
