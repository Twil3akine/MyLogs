---
import DateText from "@/components/DateText.astro";
import Tag from "@/components/Tag.astro";
import type { PostListItem } from "@/lib/content";

interface Props {
  title: string;
  description: string;
  posts: PostListItem[];
}

const { title, description, posts } = Astro.props;
---

<section class="post-list-page" data-post-list-page>
  <header>
    <h1>{title}</h1>
    <p>{description}</p>
  </header>

  <div class="filter-status" data-filter-status hidden>
    <span data-filter-label></span>
    <button type="button" data-filter-clear>Clear</button>
  </div>

  <div class="post-list">
    {
      posts.map((post) => (
        <article class="post-card" data-tags={post.tags.join("|")}>
          <div class="post-meta">
            <DateText date={post.date} size="large" />
          </div>
          <h2>
            <a class="post-title-link" href={post.href}>{post.title}</a>
          </h2>
          <p>{post.description}</p>
          <ul>
            {post.tags.map((tag) => (
              <li>
                <Tag as="button" type="button" data-filter-tag={tag}>{tag}</Tag>
              </li>
            ))}
          </ul>
        </article>
      ))
    }
  </div>
</section>

<script>
  const initPostFilters = () => {
    document.querySelectorAll<HTMLElement>("[data-post-list-page]").forEach((page) => {
      const cards = Array.from(page.querySelectorAll<HTMLElement>("[data-tags]"));
      const status = page.querySelector<HTMLElement>("[data-filter-status]");
      const label = page.querySelector<HTMLElement>("[data-filter-label]");
      const clear = page.querySelector<HTMLButtonElement>("[data-filter-clear]");
      const buttons = Array.from(page.querySelectorAll<HTMLButtonElement>("[data-filter-tag]"));

      const applyFilter = (tag: string | null) => {
        cards.forEach((card) => {
          const tags = (card.dataset.tags || "").split("|");
          card.hidden = Boolean(tag) && !tags.includes(tag);
        });

        buttons.forEach((button) => {
          button.setAttribute("aria-pressed", String(Boolean(tag) && button.dataset.filterTag === tag));
        });

        if (status && label) {
          status.hidden = !tag;
          label.textContent = tag ? `Tag: ${tag}` : "";
        }
      };

      buttons.forEach((button) => {
        button.onclick = () => applyFilter(button.dataset.filterTag || null);
      });

      if (clear) {
        clear.onclick = () => applyFilter(null);
      }
    });
  };

  initPostFilters();
  document.addEventListener("astro:page-load", initPostFilters);
</script>

<style>
  .post-list-page {
    width: 100%;
    margin: 0 auto;
    padding: clamp(2.5rem, 7vw, 5rem) 0;
  }

  .post-list-page header {
    margin-bottom: 2.25rem;
  }

  .post-list-page h1 {
    margin: 0;
    font-size: var(--font-size-page-title);
    line-height: 1.05;
  }

  .post-list-page header p {
    margin: 1.2rem 0 0;
    color: color-mix(in srgb, var(--theme-text), transparent 22%);
    font-size: var(--font-size-body-large);
    line-height: 1.9;
  }

  .filter-status {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    margin: -1.2rem 0 1.4rem;
    color: color-mix(in srgb, var(--theme-text), transparent 35%);
    font-family: var(--theme-font-mono);
    font-size: 1rem;
    font-weight: 700;
  }

  .filter-status[hidden] {
    display: none;
  }

  .filter-status button {
    border: 0;
    background: none;
    color: var(--theme-accent);
    cursor: pointer;
    font: inherit;
    padding: 0;
  }

  .post-list {
    display: grid;
    border-top: 1px solid var(--theme-border);
  }

  .post-card {
    display: grid;
    gap: 0.5rem;
    padding: 1.45rem 0 1.55rem;
    border-bottom: 1px solid var(--theme-border);
    color: var(--theme-text);
  }

  .post-card[hidden] {
    display: none;
  }

  .post-meta {
    margin: 0;
  }

  .post-card h2 {
    margin: 0;
    font-size: var(--font-size-card-title);
    line-height: 1.35;
    transition: color 0.2s ease;
  }

  .post-title-link {
    color: inherit;
    text-decoration: none;
  }

  .post-title-link:hover {
    color: var(--theme-accent);
  }

  .post-card p {
    max-width: 42rem;
    margin: 0;
    color: color-mix(in srgb, var(--theme-text), transparent 24%);
    line-height: 1.75;
  }

  .post-card ul {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin: 0.2rem 0 0;
    padding: 0;
    list-style: none;
  }

  @media (max-width: 640px) {
    .post-list-page {
      padding: 2rem 0 3rem;
    }

    .post-card {
      gap: 0.55rem;
    }
  }
</style>
