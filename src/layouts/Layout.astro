---
import "@/styles/base.css";
import "@/styles/custom.css";
import { ClientRouter } from "astro:transitions";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import ThemeToggle from "@/components/ThemeToggle.svelte";
import {
  fallbackDescriptions,
  getAlternateLocalePath,
  getLocalePrefix,
  shouldShowLanguageSwitch,
  type Locale,
} from "@/data/locales";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  lang?: Locale;
  articleDate?: string;
  type?: "website" | "article";
  frontmatter?: {
    title?: string;
    description?: string;
  };
}

const {
  title,
  description,
  image = "/ogp.png",
  lang = "ja",
  type = "website",
  articleDate,
  frontmatter
} = Astro.props;

const pageTitle = title || frontmatter?.title || "Twil3akine";
const fallbackDescription = fallbackDescriptions[lang];
const pageDescription = description || frontmatter?.description || fallbackDescription;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || Astro.url.origin);
const alternatePath = getAlternateLocalePath(Astro.url.pathname, lang);
const alternateURL = new URL(alternatePath, Astro.site || Astro.url.origin);
const showLanguageLink = shouldShowLanguageSwitch(lang);

const siteTitle = "Twil3akine";
const localePrefix = getLocalePrefix(lang);
const navLinks = [
  { href: `${localePrefix}/profile`, label: "Profile" },
  { href: `${localePrefix}/article`, label: "Article" },
  { href: `${localePrefix}/blog`, label: "Blog" },
];
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={canonicalURL} />
    {showLanguageLink && <link rel="alternate" hreflang={lang === "en" ? "ja" : "en"} href={alternateURL} />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;600;700;800&family=Ubuntu+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    {image && <meta property="og:image" content={new URL(image, canonicalURL)} />}

    <!-- Article Specific -->
    {type === 'article' && articleDate && <meta property="article:published_time" content={articleDate} />}

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={pageTitle} />
    <meta property="twitter:description" content={pageDescription} />
    {image && <meta property="twitter:image" content={new URL(image, canonicalURL)} />}

    <ClientRouter />

    <style>
      .layout-container {
        display: flex;
        max-width: 1200px;
        margin: 0 auto;
        padding: 2rem;
        gap: 2.5rem;
        align-items: flex-start;
        flex: 1;
        width: 100%;
        box-sizing: border-box;
      }

      .main-content {
        flex: 1;
        min-width: 0;
      }

      .language-link {
        display: inline-flex;
        justify-content: center;
        align-items: center;
        width: 2rem;
        min-height: 1.75rem;
        font-size: 0.85rem;
        font-weight: 700;
        text-decoration: none;
      }
    </style>

    <script is:inline>
      const setTheme = () => {
        const theme = (() => {
          if (
            typeof localStorage !== "undefined" &&
            localStorage.getItem("theme")
          ) {
            return localStorage.getItem("theme");
          }
          if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
            return "dark";
          }
          return "light";
        })();
        document.documentElement.dataset.theme = theme;
      };

      // 初回読み込み時に実行
      setTheme();
      // ViewTransitionsでのページ遷移後に再実行
      document.addEventListener("astro:after-swap", setTheme);
    </script>
  </head>
  <body>
    <Header siteTitle={siteTitle} navLinks={navLinks}>
      <div
        slot="actions"
        style="display: flex; align-items: center; gap: 1.25rem;"
      >
        <ThemeToggle client:load />
        {
          showLanguageLink && (
            <a
              href={alternatePath}
              aria-label={lang === "en" ? "日本語版へ" : "English version"}
              class="language-link"
            >
              {lang === "en" ? "EN" : "JA"}
            </a>
          )
        }
      </div>
    </Header>

    <div class="layout-container">
      <main class="main-content">
        <slot />
      </main>
    </div>

    <Footer />
  </body>
</html>
