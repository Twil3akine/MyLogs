---
interface Option {
  value: string;
  count: number;
}

interface Props {
  options: Option[];
  totalCount: number;
  locale?: "ja" | "en";
}

const { options, totalCount, locale = "ja" } = Astro.props;
const labels = locale === "ja"
  ? { name: "タグ", all: "すべて" }
  : { name: "Tags", all: "All" };
---

<div class="tag-select" aria-label={labels.name}>
  <div class="options" role="group" aria-label={labels.name}>
    <button type="button" data-filter-tag="" aria-pressed="true">
      <span>{labels.all}</span>
      <span class="option-count">{totalCount}</span>
    </button>
    {
      options.map(({ value, count }) => (
        <button type="button" data-filter-tag={value} aria-pressed="false">
          <span class="hash">#</span>
          <span>{value}</span>
          <span class="option-count">{count}</span>
        </button>
      ))
    }
  </div>
</div>

<style>
  .tag-select {
    display: flex;
    align-items: center;
  }

  .options {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  button {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    min-height: 2rem;
    padding: 0 0.5rem 0 0.75rem;
    border: 1px solid var(--theme-border);
    border-radius: 8px;
    background: transparent;
    color: color-mix(in srgb, var(--theme-text), transparent 18%);
    cursor: pointer;
    font: inherit;
    font-size: 0.86rem;
    font-weight: 600;
    transition:
      border-color 0.2s ease,
      background-color 0.2s ease,
      color 0.2s ease;
  }

  button:hover {
    border-color: var(--theme-accent);
    color: var(--theme-accent);
    background-color: var(--theme-accent-bg);
  }

  button[aria-pressed="true"] {
    border-color: var(--theme-text);
    background-color: var(--theme-text);
    color: var(--theme-bg);
  }

  .hash {
    color: var(--theme-accent);
  }

  button[aria-pressed="true"] .hash {
    color: currentColor;
  }

  .option-count {
    display: inline-grid;
    place-items: center;
    min-width: 1.5rem;
    height: 1.5rem;
    padding: 0 0.3rem;
    border-radius: 4px;
    background-color: color-mix(in srgb, var(--theme-text), transparent 91%);
    font-family: var(--theme-font-mono);
    font-size: 0.86rem;
    line-height: 1;
    transition: background-color 0.2s ease;
  }

  button[aria-pressed="true"] .option-count {
    background-color: color-mix(in srgb, var(--theme-bg), transparent 82%);
  }

</style>
