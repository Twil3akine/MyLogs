---
import { getCollection } from "astro:content";
import { LinkCard } from "@astrojs/starlight/components";

const logs = await getCollection("docs", ({ id }) => {
    return id.startsWith("logs/") && !id.endsWith("index");
});
---

{
    logs.map((log) => {
        const splitedFilePath = log.filePath?.split("/");
        const folder = splitedFilePath?.at(-2);
        const file = splitedFilePath
            ?.at(-1)
            ?.replace(/\.mdx$/, "")
            .toLowerCase();
        const filePath = `/${folder}/${file}`;

        return (
            <LinkCard
                title={log.data.title}
                href={`${filePath}`}
                description={log.data.description ?? ""}
            />
        );
    })
}
