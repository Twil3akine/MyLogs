---
interface Props {
  href?: string;
  as?: "span" | "button";
  class?: string;
  type?: "button";
  [key: string]: unknown;
}

const { href, as, class: className, ...attrs } = Astro.props;
const Element = href ? "a" : as === "button" ? "button" : "span";
---

<Element href={href} class:list={["tag", className]} {...attrs}>
  <span class="hash">#</span>
  <slot />
</Element>

<style>
  .tag {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    min-height: 2rem;
    padding: 0 0.75rem;
    border: 1px solid var(--theme-border);
    border-radius: 8px;
    background-color: transparent;
    color: color-mix(in srgb, var(--theme-text), transparent 18%);
    font-size: 0.86rem;
    font-weight: 600;
    line-height: 1;
    text-decoration: none;
    transition:
      border-color 0.2s ease,
      background-color 0.2s ease,
      color 0.2s ease;
  }

  button.tag {
    cursor: pointer;
    font-family: inherit;
  }

  .hash {
    color: var(--theme-accent);
  }

  a.tag:hover,
  button.tag:hover {
    border-color: var(--theme-accent);
    background-color: var(--theme-accent-bg);
    color: var(--theme-accent);
  }

  button.tag[aria-pressed="true"] {
    border-color: var(--theme-text);
    background-color: var(--theme-text);
    color: var(--theme-bg);
  }

  button.tag[aria-pressed="true"] .hash {
    color: currentColor;
  }
</style>
