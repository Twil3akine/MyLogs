---
export interface Props {
  siteTitle?: string;
}

const { siteTitle = "Twil3akine" } = Astro.props;
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-inner">
    <div class="footer-content">
      {
        Astro.slots.has("default") && (
          <div class="footer-actions">
            <slot />
          </div>
        )
      }
      <p class="copyright">
        &copy; {currentYear}
        {siteTitle}. All rights reserved.
      </p>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--theme-border);
    background-color: var(--theme-bg);
    margin-top: 1.5rem;
  }
  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 1.5rem 2rem;
  }
  .footer-content {
    display: flex;
    flex-direction: column; /* 縦並びに変更 */
    justify-content: center;
    align-items: center;
    gap: 0.75rem;
  }
  .copyright {
    margin: 0;
    font-size: 0.85rem;
    color: var(--theme-text);
    opacity: 0.6;
    text-align: center;
  }
  .footer-actions {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }
  /* スロットで渡されたリンクのスタイルとホバー設定 */
  .footer-actions :global(a) {
    color: var(--theme-text-muted);
    transition: color 0.2s ease;
    display: flex;
    align-items: center;
  }
  .footer-actions :global(a:hover) {
    color: var(--theme-accent);
  }
</style>
