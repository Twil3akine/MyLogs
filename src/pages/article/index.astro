---
import PostListPage from "@/components/PostListPage.astro";
import { getCollection } from "astro:content";
import {
  isPostLocale,
  isPublishedPost,
  sortPostsByDateDesc,
  toPostListItem,
} from "@/lib/content";
import Layout from "@/layouts/Layout.astro";

const posts = sortPostsByDateDesc(
  (await getCollection("article")).filter(
    (post) => isPublishedPost(post) && isPostLocale(post, "ja"),
  ),
)
  .map((post) => toPostListItem(post, "/article"));
---

<Layout
  title="Article | Twil3akine"
  description="競技プログラミング、開発、学んだことをあとから読める形で残します。"
  lang="ja"
>
  <PostListPage
    title="Article"
    description="競プロ、開発、学んだことを、あとから読み返せる密度で整理する場所です。"
    posts={posts}
    locale="ja"
  />
</Layout>
